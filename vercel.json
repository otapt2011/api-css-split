{
  "version": 2,
  "builds": [
    {
      "src": "api/split.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/split",
      "dest": "/api/split.js",
      "methods": ["POST", "OPTIONS"]
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html",
      "methods": ["GET"]
    }
  ],
  "functions": {
    "api/split.js": {
      "maxDuration": 30,
      "runtime": "nodejs18.x"
    }
  }
}
